{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "ZeroClawX",
    "version":  "0.1.0",
    "identifier":  "com.zeroclawx.desktop",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build",
                  "devUrl":  "http://localhost:1420",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "ZeroClawX",
                                    "width":  1440,
                                    "height":  960,
                                    "minWidth":  1080,
                                    "minHeight":  720,
                                    "resizable":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  false,
                   "targets":  "all"
               },
    "plugins":  {
                    "updater":  {
                                    "pubkey":  "",
                                    "endpoints":  [

                                                  ]
                                }
                }
}
